nextflow_process {

    name "Test Process RM_LOWQ_READS"
    script "../main.nf"
    process "RM_LOWQ_READS"
    config "./test.config"
    tag "samtools"
    tag "encode"

    test("run pe successfully") {
        when {
            params {
                args = ""
                qthresh = 30
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id: "100k_ENCFF203LSX", single_end: false],file("${moduleDir}/tests/100k_ENCFF203LSX.bam")]
                input[1] = ${params.qthresh}
                """
            }
        }
        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

    test("run se successfully") {
        when {
            params {
                args = ""
                qthresh = 30
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id: "100k_ENCFF203LSX", single_end: true],file("${moduleDir}/tests/100k_ENCFF203LSX.bam")]
                input[1] = ${params.qthresh}
                """
            }
        }
        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

    test("ignore q threshold when empty") {
        when {
            params {
                args = ""
                qthresh = []
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id: "100k_ENCFF203LSX", single_end: false],file("${moduleDir}/tests/100k_ENCFF203LSX.bam")]
                input[1] = ${params.qthresh}
                """
            }
        }
        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

}
