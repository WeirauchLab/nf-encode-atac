nextflow_process {

    name "Test Process RM_DUPLICATES"
    script "../main.nf"
    process "RM_DUPLICATES"

    test("run pe successfully") {
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id: "100k_ENCFF203LSX", single_end: false], file("${moduleDir}/tests/100k_ENCFF203LSX.bam")]
                """
            }
        }
        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

    test("run se successfully") {
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = [[id: "100k_ENCFF203LSX", single_end: true], file("${moduleDir}/tests/100k_ENCFF203LSX.bam")]
                """
            }
        }
        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

}
