nextflow_process {

    name "Test Process TXDBMAKER_MAKETXDBFROMGFF"
    script "../main.nf"
    process "TXDBMAKER_MAKETXDBFROMGFF"
    config "./test.config"

    test("Should run without failures") {
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                // define inputs of the process here. Example:
                input[0] = [ [id: "test_gtf"], file("${moduleDir}/tests/gencode.v49.1k.gtf.gz") ]
                input[1] = []
                """
            }
        }
        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }
    test("Includes chrsizes when provided") {
        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                // define inputs of the process here. Example:
                input[0] = [ [id: "test_gtf"], file("${moduleDir}/tests/gencode.v49.1k.gtf.gz") ]
                input[1] = file("${moduleDir}/tests/hg38.chrom.sizes")
                """
            }
        }
        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

}
